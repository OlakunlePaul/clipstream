{
  "manifest_version": 3,
  "name": "ClipStream",
  "version": "1.0.3",
  "description": "Seamless cross-device clipboard sync.",
  "permissions": [
    "clipboardRead",
    "offscreen",
    "storage",
    "alarms"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  }
}
